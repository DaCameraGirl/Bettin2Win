{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @bettin2win/types build && pnpm --filter @bettin2win/odds-engine build"
  },
  "deploy": {
    "startCommand": "node services/odds-engine/dist/index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
