# Bettin2Win - environment variables
# Copy this file to ".env" and fill in real values. NEVER commit .env.
#
# Each sport runs in "mock" mode until its provider credentials are present,
# so the app boots and renders with zero keys. Drop a key in and that sport
# flips to "live" automatically on the next poll.

# --- The Odds API (football, baseball) ---
# https://dash.the-odds-api.com  -> key is passed as ?apiKey= in the URL
ODDS_API_KEY=

# --- TheRundown (NASCAR / motorsport) ---
# https://therundown.io/pricing/api  -> sent as X-TheRundown-Key header
THERUNDOWN_API_KEY=

# --- The Racing API (horse racing) ---
# https://theracingapi.com  -> HTTP Basic Auth (username + password, NOT a single key)
RACING_API_USERNAME=
RACING_API_PASSWORD=

# --- BetsAPI (greyhound racing) ---
# https://betsapi.com/docs  -> token passed as ?token= in the URL
BETSAPI_KEY=

# --- Highlightly (via RapidAPI) -- enrichment: teams, standings, form ---
# https://rapidapi.com/highlightly-api  -> x-rapidapi-key header
# Basic plan = match data only (NO odds). Used for context, not prices.
HIGHLIGHTLY_API_KEY=

# --- Prediction providers (via RapidAPI) -- soccer model picks ---
# football-prediction-api on RapidAPI -> x-rapidapi-key header.
# One RapidAPI account = one key across all your subscribed prediction APIs,
# so this is typically the SAME value as HIGHLIGHTLY_API_KEY above.
RAPIDAPI_KEY=

# --- AI explanation layer (optional) ---
# Leave blank to use the built-in templated explanations (no external call).
AI_PROVIDER=template
AI_API_KEY=

# --- Server ---
ODDS_ENGINE_PORT=4000
WEB_PORT=5173

# Optional durable-ish closing-line history path.
# Defaults to .data/closing-lines.json on the engine host.
ODDS_HISTORY_FILE=
